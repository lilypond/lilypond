msgid "BEATS/BEATTYPE"
msgstr "TELLEN/MAATTYPE"

#: musicxml2ly.py:5369
msgid "`--shift-meter` is obsolete and ignored, use `--shift-duration` instead"
msgstr ""
"`--shift-meter` is verouderd en wordt genegeerd;\n"
"gebruik in de plaats daarvan `--shift-duration`"

#: musicxml2ly.py:5371
msgid "ignored; use `--shift-duration` instead"
msgstr "genegeerd; gebruik `--shift-duration` in de plaats"

#: musicxml2ly.py:5375
msgid "TABCLEFNAME"
msgstr "TABSLEUTELNAAM"

#: musicxml2ly.py:5378
msgid "switch between two versions of tab clefs (\"tab\" and \"moderntab\")"
