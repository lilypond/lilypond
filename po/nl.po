#: musicxml2ly.py:5208
msgid "--lxml is obsolete, ignoring"
msgstr "--lxml is verouderd; genegeerd"

#: musicxml2ly.py:5209
msgid "obsolete"
msgstr "verouderd"

#: musicxml2ly.py:5215
msgid "input file is a compressed MusicXML file (by default, activate if file extension is .mxl)"
msgstr ""
"invoerbestand is een gecomprimeerd MusicXML-bestand (standaard\n"
"activeren als de bestandsextensie .mxl is)"

#: musicxml2ly.py:5222
msgid "convert pitches in relative mode (default)"
msgstr "toonhoogtes converteren in relatieve modus (standaard)"

#: musicxml2ly.py:5227
msgid "convert pitches in absolute mode"
msgstr "toonhoogtes converteren in absolute modus"

#: musicxml2ly.py:5230
msgid "LANG"
msgstr "TAAL"

#: musicxml2ly.py:5232
msgid "use LANG for pitch names, e.g., 'deutsch' for note names in German"
msgstr ""
"deze TAAL gebruiken voor toonhoogtenamen; b.v. 'deutsch'\n"
"voor nootnamen in het Duits"

#: musicxml2ly.py:5244 musicxml2ly.py:5383
msgid "t[rue]/f[alse]"
msgstr "t[rue]/f[alse] (w[aar]/o[nwaar])"

#: musicxml2ly.py:5247
msgid "expect <octave-shift> end elements before the associated <note> (as in Finale). Default is f[alse]"
msgstr ""
"verwachten dat <octaafverschuiving>-einde-elementen vóór de\n"
"bijbehorende <noot> worden geplaatst (zoals in Finale).\n"
"De standaardwaarde is f[alse] (onwaar)."

#: musicxml2ly.py:5255
msgid "do not convert directions (^, _ or -) for articulations, dynamics, etc."
msgstr ""
"de aanwijzingen (^, _ of -) voor articulatie, dynamiek en dergelijke\n"
"niet converteren"

#: musicxml2ly.py:5262
msgid "do not convert exact vertical positions of rests"
msgstr "de exacte verticale plaatsing van rusten niet converteren"

#: musicxml2ly.py:5268
msgid "ignore system breaks"
msgstr "systeemafbrekingen genegeerd"

#: musicxml2ly.py:5274
msgid "ignore page breaks"
msgstr "pagina-einden genegeerd"

#: musicxml2ly.py:5280
msgid "ignore page margins"
msgstr "marges genegeerd"

#: musicxml2ly.py:5286
msgid "do not convert the exact page layout and breaks (shortcut for \"--nsb --npb --npm\" options)"
msgstr ""
"de exacte paginaopmaak en pagina-einden niet converteren\n"
"(afkorting voor de opties \"--nsb --npb --npm\")"

#: musicxml2ly.py:5293
msgid "ignore stem directions from MusicXML, use lilypond's automatic stemming instead"
msgstr ""
"de richting van nootstokken uit MusicXML genegeerd; in plaats daarvan\n"
"automatisch nootstokken laten plaatsen door lilypond"

#: musicxml2ly.py:5297
msgid "FACTOR"
msgstr "FACTOR"

#: musicxml2ly.py:5302
msgid "scale <dynamics> elements by a non-negative FACTOR; value 0 means to use lilypond's standard size for dynamics"
msgstr ""
"<dynamiek>-elementen schalen met een niet-negatieve FACTOR;\n"
"de waarde 0 betekent dat de standaardgrootte van LilyPond voor\n"
"dynamieken wordt gebruikt"

#: musicxml2ly.py:5310
msgid "use absolute font sizes in markup (default is to use font sizes based on score size)"
msgstr ""
"absolute lettergroottes gebruiken in de opmaak (standaard worden\n"
"lettergroottes gebruikt die zijn gebaseerd op de partituurgrootte)"

#: musicxml2ly.py:5317
msgid "do not convert beaming information, use lilypond's automatic beaming instead"
msgstr ""
"geen informatie i.v.m. waardestrepen converteren; in plaats daarvan\n"
"automatisch waardestrepen laten plaatsen door lilypond"

#: musicxml2ly.py:5326
msgid "set output filename to FILE, stdout if -"
msgstr "uitvoer opslaan in BESTAND, standaarduitvoer indien -"

#: musicxml2ly.py:5332
msgid "activate midi-block in .ly file"
msgstr "midi-blok activeren in .ly-bestand"

#: musicxml2ly.py:5335
msgid "N"
msgstr "N"

#: musicxml2ly.py:5340
msgid "use <credit> information from page N to fill the fields of the \\header block. Default is value 1"
msgstr ""
"de <auteurs>-informatie van pagina N gebruiken om de velden van\n"
"het \\header-blok in te vullen. De standaardwaarde is 1"

#: musicxml2ly.py:5346
msgid "TOPITCH"
msgstr "NAARTOONHOOGTE"

#: musicxml2ly.py:5349
msgid "set pitch to transpose by the interval between pitch 'c' and TOPITCH"
msgstr ""
"de toonhoogte voor de transpositie instellen met het interval tussen\n"
"toonhoogte 'c' en NAARTOONHOOGTE"

#: musicxml2ly.py:5354
msgid "VALUE"
msgstr "WAARDE"

#: musicxml2ly.py:5359
msgid "shift durations and time signatures by VALUE; for example, value -1 doubles all durations, and value 1 halves them"
msgstr ""
"duur en maatsoorten aanpassen met de parameter WAARDE; de\n"
"waarde -1 verdubbelt bijvoorbeeld alle duren, en de waarde 1 halveert ze"

