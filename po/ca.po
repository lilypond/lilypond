msgstr "O deseu com a UTF-8 al vostre editor"

#: convertrules.py:2228
msgid "auto beam settings"
msgstr "paràmetres de barrat automàtic"

#: convertrules.py:2229
msgid ""
"\n"
"Auto beam settings must now specify each interesting moment in a measure\n"
"explicitly; 1/4 is no longer multiplied to cover moments 1/2 and 3/4 too.\n"
msgstr ""
"\n"
"Els paràmetres per a barres automàtiques han d'especificar ara\n"
"explícitament cada  moment interessant en un compàs; no es multiplica\n"
"més la duració 1/4 per cobrir també duracions d'1/2 i 3/4.\n"

#: convertrules.py:2340
msgid "verticalAlignmentChildCallback has been deprecated"
msgstr "verticalAlignmentChildCallback ha caigut en desús"

#: convertrules.py:2677
msgid "edge-text settings for TextSpanner"
msgstr "Paràmetres edge-text per a TextSpanner"

#: convertrules.py:2678
#, python-format
msgid ""
"Use\n"
"\n"
"%s"
msgstr ""
"Useu\n"
"\n"
"%s"

#: convertrules.py:2711
msgid "Use the `alignment-offsets' sub-property of\n"
msgstr "Useu la sub-propietat «alignment-offsets» de\n"

#: convertrules.py:2712
msgid "NonMusicalPaperColumn #'line-break-system-details\n"
msgstr "NonMusicalPaperColumn #'line-break-system-details\n"

#: convertrules.py:2713
msgid "to set fixed distances between staves.\n"
msgstr "per establir distàncies fixes entre pautes.\n"

#: convertrules.py:2731
msgid "all settings related to dashed lines"
msgstr "tots els paràmetres relacionats amb línies intermitents"

#: convertrules.py:2733
msgid "Use \\override ... #'style = #'line for solid lines and\n"
msgstr "Useu \\override ... #'style = #'line per a línies sòlides i\n"

#: convertrules.py:2735
msgid "\t\\override ... #'style = #'dashed-line for dashed lines."
msgstr "\t\\override ... #'style = #'dashed-line per a línies intermitents."

#: convertrules.py:2778
msgid "metronomeMarkFormatter got an additional text argument.\n"
msgstr "metronomeMarkFormatter té un argument de text addicional.\n"

#: convertrules.py:2779
#, python-format
msgid ""
"The function assigned to Score.metronomeMarkFunction now uses the signature\n"
"%s"
msgstr ""
"La funció assignada a Score.metronomeMarkFunction utilitza ara la firma\n"
"%s"

#: convertrules.py:2798
#, python-format
msgid "%s in fret-diagram properties"
msgstr "%s a propietats fret-diagram"

#: convertrules.py:2848
msgid "\\put-adjacent argument order"
msgstr "ordre d'arguments de \\put-adjacent"

#: convertrules.py:2849
msgid "Axis and direction now come before markups:\n"
msgstr "Els eixos i la direcció venen ara abans dels formats:\n"

#: convertrules.py:2850
msgid "\\put-adjacent axis dir markup markup."
msgstr "\\put-adjacent eix carpeta marcat marcat"

#: convertrules.py:2888
msgid "re-definition of InnerStaffGroup"
msgstr "re-definició d'InnerStaffGroup"

#: convertrules.py:2893
msgid "re-definition of InnerChoirStaff"
msgstr "re-definició d'InnerChoirStaff"

#: convertrules.py:2908
msgid "stringTuning must be added to addChordShape call.\n"
msgstr "S'ha d'afegir stringTuning a la crida addChordShape.\n"

#: convertrules.py:2913
msgid "stringTuning must be added to chord-shape call.\n"
msgstr "S'ha d'afegir stringTuning a la crida chord-shape.\n"

#: convertrules.py:2923
msgid ""
"oldaddlyrics is no longer supported. \n"
"         Use addlyrics or lyricsto instead.\n"
msgstr ""
"oldaddlyrics ha deixat d'estar suportat. \n"
"         Useu en canvi addlyrics o lyrsicsto.\n"

#: convertrules.py:2935
msgid "The alist for Staff.keySignature is no longer in reversed order.\n"
msgstr "La llista-A per a Staff,keySignature ja no està en ordre invers.\n"

#: convertrules.py:2947
msgid "\\bar \".\" now produces a thick barline.\n"
msgstr "\\bar \".\" produeix ara una línia divisòria gruixuda.\n"

#: convertrules.py:2955
msgid "Dash parameters for slurs and ties are now in 'dash-definition.\n"
msgstr "Els paràmetres de guionet per a lligadures d'expressió i d'unió estan ara a 'dash-definition.\n"

#: convertrules.py:2974
msgid "    Autobeam settings are now overriden with \\overrideBeamSettings.\n"
msgstr "    Els paràmetres de autobarrat es sobreescriuen ara amb \\overrideBeamSettings.\n"

#: convertrules.py:2979
msgid "    Autobeam settings are now reverted with \\revertBeamSettings.\n"
msgstr "    Els paràmetres de autobarrat es reverteixen ara amb \\revertBeamSettings.\n"

#: convertrules.py:2985
msgid ""
"    beatGrouping with a specified context must now be accomplished with\n"
"   \\overrideBeamSettings.\n"
msgstr ""
"    beatGrouping amb un context especificat s'aconsegueix ara amb\n"
"   \\overrideBeamSettings.\n"

#: convertrules.py:2991
msgid "alignment-offsets has been changed to alignment-distances: you must now specify the distances between staves rather than the offset of staves.\n"
msgstr "alignment-offsets ha canviat a alignment-distances: ara s'han d'especificat les distàncies entre pautes enlloc del desplaçament de cada pauta.\n"

#: convertrules.py:3034
msgid "Vertical spacing no longer depends on the Y-extent of a VerticalAxisGroup.\n"
msgstr "L'espaiament vertical ja no depèn de l'Y-extent d'un VerticalAxisGroup.\n"

#: convertrules.py:3088
msgid "Use \\set beamExceptions or \\overrideTimeSignatureSettings.\n"
msgstr "Useu \\set beamExceptions o \\overrideTimeSignatureSettings.\n"

#: convertrules.py:3093
msgid "Use \\set beamExceptions or \\revertTimeSignatureSettings.\n"
msgstr "Useu \\set beamExceptions o \\revertTimeSignatureSettings.\n"

#: convertrules.py:3097
msgid "Use baseMoment, beatStructure, and beamExceptions.\n"
msgstr "Useu baseMoment i beatStructure.\n"

#: convertrules.py:3101 convertrules.py:3105
msgid "Use baseMoment and beatStructure.\n"
msgstr "Useu baseMoment i beatStructure.\n"

#: convertrules.py:3117
msgid "Move size, thickness, and graphic to properties.  Argument should be just the key list.\n"
msgstr "Moveu la mida, el gruix i la gràfica a propietats. L'argument hauria de ser sols la llista de claus.\n"

#: convertrules.py:3169
msgid "Adjust settings for top-system-spacing instead.\n"
msgstr "Ajusteu en canvi els paràmetres per a top-system-spacing.\n"

#: convertrules.py:3173
msgid "Adjust settings for last-bottom-spacing instead.\n"
msgstr "Ajusteu en canvi els paràmetres per a last-bottom-spacing.\n"

#: convertrules.py:3188
msgid "HarmonicParenthesesItem has been eliminated.\n"
msgstr "S'ha eliminat HarmonicParenthesesItem.\n"

#: convertrules.py:3190
msgid "Harmonic parentheses are part of the TabNoteHead grob.\n"
msgstr "Els parèntesis d'harmònics formen part de l'objecte gràfic TabNoteHead.\n"

#: convertrules.py:3247
msgid "Vertical spacing changes might affect user-defined contexts."
msgstr "Els canvis d'espaiament vertical poden afectar els contextos definits per l'usuari"

#: convertrules.py:3269
msgid "Clarinet fingering changed to reflect actual anatomy of instrument.\n"
msgstr "La digitació del clarinet ha canviat per reflectir l'anatomia real l'instrument.\n"

#: convertrules.py:3284
msgid "If you are using non-automatic footnotes, make sure to set footnote-auto-numbering = ##f in the paper block.\n"
msgstr ""
"Si esteu usant notes a peu de pàgina no automàtiques, assegureu-vos\n"
" d'establir footnote-autonumbering = ##f al bloc de paper.\n"

#: convertrules.py:3294
msgid "This internal property has been replaced by round-up-to-longer-rest, round-up-exceptions and usable-duration-logs.\n"
msgstr "Aquesta propietat interna s'ha substituït per round-up-to-longer-rest, round-up-exceptions i usable-duration-logs.\n"

#: convertrules.py:3342
msgid "consistent-broken-slope is now handled through the positions callback.\n"
msgstr "Ara es gestiona consistent-broken-slope mitjançant crida de retorn de posicions.\n"

#: convertrules.py:3344
msgid "input/regression/beam-broken-classic.ly shows how broken beams are now handled.\n"
msgstr "input/regression/beam-broken-classic.ly mostra com es gestionen ara les barres dividides.\n"

#: convertrules.py:3514
msgid "beamExceptions controls whole-measure beaming."
msgstr "beamExceptions controla el barrat de compassos complets."

#: convertrules.py:3860
msgid ""
"\n"
"staff-padding now controls the distance to the baseline, not the nearest point.\n"
msgstr ""
"\n"
"staff-padding ara controla la distància de la base, no el punt més proper.\n"

#: convertrules.py:4154
msgid ""
"\n"
"Previously the \"id\" grob property (string) was used for SVG output.\n"
"Now \"output-attributes\" (association list) is used instead.\n"
msgstr ""
"\n"
"Es va usar prèviament la propietat «id» d'objecte gràfic (cadena de caràcters) per a la sortida SVG.\n"
"Ara s'usa en canvi «output-atributes» (llista d'associacions).\n"

#: convertrules.py:4261
msgid "alternative chord naming functions"
msgstr "funcions alternatives de nomenclatura d'acord"

#: convertrules.py:4277
msgid ""
"\n"
"Instead of (for example)\n"
"  \\markup \\override #'(multi-measure-rest . #t) \\rest-by-number #0 #0\n"
"use\n"
"  \\markup \\multi-measure-rest-by-number #1\n"
"\n"
"The argument of \\multi-measure-rest-by-number is the number of measures\n"
"the multi-measure rest lasts.\n"
msgstr ""
"\n"
"En lloc de (per exemple)\n"
"  \\markup \\override .'(multi-measure-rest . \\t) \\rest-by-number  0  0\n"
"useu\n"
"  \\markup \\multi-measure-rest-by-number 11\n"
"\n"
"L'argument de \\multi-measure-rest-by-number és el nombre de compassos que dura el silenci multi-mesura.\n"

#: convertrules.py:4313
msgid ""
"\n"
"If you had\n"
"\n"
"  \\override Stem.neutral-direction = #DOWN\n"
"\n"
"and\n"
"\n"
"  \\override Stem.neutral-direction #'()\n"
"\n"
"to turn the use of the Melody_engraver off\n"
"and on, respectively, you should instead use\n"
"\n"
"  \\set suspendMelodyDecisions = ##t\n"
"\n"
"and\n"
"\n"
"  \\set suspendMelodyDecisions = ##f\n"
"\n"
msgstr ""
"\n"
"Si teníeu\n"
"\n"
"  \\override Stem.neutral-direction    DOWN\n"
"\n"
"i\n"
"\n"
"  \\override Stem.neutral-direction  '()\n"
"\n"
"per desactivar i tornar a activar l'ús del Melodyengraver, respectivament, heu d'utilitzar en canvi\n"
"\n"
"\\\\set suspendMelodyDecisions = ##t\n"
"\n"
"i\n"
"\n"
"\\\\set suspendMelodyDecisions = ##f\n"

#: convertrules.py:4359
msgid "Stem.neutral-direction with Melody_engraver"
msgstr "Stem.neutral-direction amb Melody_engraver"

#: convertrules.py:4368
msgid ""
"\n"
"ly:round-filled-polygon was renamed to ly:round-polygon and now takes\n"
"an additional optional parameter specifying whether the polygon is filled.\n"
"The default value of the extroversion optional parameter was changed from\n"
"-1 to 0.\n"
msgstr ""
"\n"
"ly:round-filled-polygon va ser rebatejat com ly:round-polygon i ara\n"
"pren un paràmetre opcional addicional que especifica si el polígon està omplert.\n"
"El valor per defecte del paràmetre opcional d'extroversió s'ha canviat\n"
"des de -1 a 0.\n"

#: convertrules.py:4445
msgid ""
"\n"
"If independent mark sequences are desired, use multiple Mark_tracking_translators.\n"
msgstr ""
"\n"
"Si es desitgen seqüències independents de marca, useu Mark_tracking_translators múltiples.\n"

#: convertrules.py:4462
msgid ""
"\n"
"The signature of the markup->string Scheme function changed.  Calls with\n"
"just one argument are not affected.  Calls using the second optional\n"
"argument, the list of header modules, should be changed from\n"
"\n"
"  (markup->string <markup> <header list>)\n"
"\n"
"to\n"
"\n"
"  (markup->string <markup> #:props (headers-property-alist-chain <header list>))\n"
"\n"
msgstr ""
"\n"
"La signatura de la funció markup->string de l'Scheme ha canviat.  Crides  amb només un argument no es veuen afectades. Crides que utilitzen el segon argument opcional, la llista de mòduls de capçalera, s'han de canviar des de\n"
"\n"
"  (markup->string <marca> <llista de capçaleres>)\n"
"\n"
"a\n"
"\n"
"  (markup->string <marca>  :props (headers-property-alist-chain <llista de capçaleres>))\n"

#: convertrules.py:4519
msgid ""
"\n"
"Warning:\n"
"\n"
"Your score contains a setting of barNumberVisibility to\n"
"#all-bar-numbers-visible and a setting of BarNumber.break-visibility,\n"
"but not \\bar \"\" command.  This likely means that you have\n"
"been using\n"
"\n"
"  \\set Score.barNumberVisibility = #all-bar-numbers-visible\n"
"  \\override Score.BarNumber.break-visibility = #end-of-line-invisible\n"
"\n"
"in order to print bar numbers in the middle of systems\n"
"in addition to bar numbers at the beginning of systems.\n"
"In 2.23.7 and later, this will print the first bar number\n"
"too, which has always been the intended effect of\n"
"#all-bar-numbers-visible, but did not work without \\bar \"\"\n"
"for technical reasons.  If you do not want the first\n"
"bar number, remove the command\n"
"\n"
"  \\set Score.barNumberVisibility = #all-bar-numbers-visible\n"
msgstr ""
"\n"
"Advertiment:\n"
"\n"
"La vostra partitura conté un paràmetre barNumberVisibility establert\n"
"a #all-bar-numbers-visible i un paràmetre BarNumber.break-visibility,\n"
"però cap ordre \\bar \"\". Això probablement significa que heu estat\n"
"usant\n"
"\n"
"  \\set Score.barNumberVisibility = #all-bar-numbers-visible\n"
"  \\override Score.BarNumber.break-visibility = #end-of-line-invisible\n"
"\n"
"per primer els nombres de barra al mig dels sistemes a\n"
"més de nombre de barres a l'inici dels sistemes. A 2.23.7\n"
"i posterior, això imprimirà també el primer nombre de barra,\n"
"cosa que ha estat sempre l'efecte buscat de\n"
"#all-bar-numbers-visible, però que no funcionava sense \\bar \"\"\n"
"per raons tècniques. Si no voleu el primer nombre de barra,\n"
"suprimiu l'ordre\n"
"\n"
"  \\set Score.barNumberVisibility = #all-bar-numbers-visible\n"

#: convertrules.py:4577
msgid ""
"\n"
"The X-offset property of PercentRepeat is no longer relative to the\n"
"default position (centered), but to the left of the span within\n"
"which the object is centered.  Overrides/tweaks to PercentRepeat.X-offset\n"
"should be updated.\n"
msgstr ""
"\n"
"La propietat X-offset de PercentRepeat ja no és relativa a\n"
"posició per defecte (centrada), sinó a l'esquerra de l'espai dins\n"
"del qual l'objecte està centrat.  Omissions/ajustos a PercentRepeat.X-offset\n"
"s'han d'actualitzar.\n"

#: convertrules.py:4596
msgid ""
"\n"
"The automaticBars property has been removed.  Instead, set\n"
"measureBarType to #'() or a valid bar type.\n"
msgstr ""
"\n"
"La propietat automaticBars property s'ha suprimit.  Establiu en canvi\n"
"measureBarType a #'() o un tipus de barra de compàs vàlida.\n"

#: convertrules.py:4614
msgid "advanced use of automaticBars"
msgstr "ús avançat de automaticBars"

#: convertrules.py:4660
msgid ""
"\n"
"Warning: \\fine no longer enforces the end of the music.  If your piece\n"
"has music following \\fine that you want to exclude when it is\n"
"unfolded, use \\volta to exclude it.\n"
msgstr ""
"\n"
"Advertiment: \\fine ja no imposa la finalització de la música.  Si la\n"
"vostra peça té música després de \\fine que voleu excloure quan es\n"
"desplega, useu \\volta per excloure-la.\n"

#: convertrules.py:4666
msgid ""
"\n"
"MensuralStaff and VaticanaStaff now use Divisio_engraver to engrave\n"
"divisiones as Divisio grobs.\n"
"\n"
"Previously, the respective Voice-aliased contexts used\n"
"Breathing_sign_engraver to engrave divisiones as BreathingSign grobs.\n"
"Because of the new names and the move from Voice to Staff, layout\n"
"adjustments for the old scheme are not effective for the new.\n"
"\n"
"If you are not content with the new default layout, deal with Divisio\n"
"and Divisio_engraver in the appropriate Staff-aliased context.\n"
msgstr ""
"\n"
"MensuralStaff i VaticanaStaff ara usen Divisio_engraver per gravar\n"
"divisiones com a grobs Divisio.\n"
"\n"
"Anteriorment, els contextos respectius Voice-aliaes usaven el\n"
"sign_engraver Breathing per gravar divisiones com a grobs\n"
"BreathingSign. A causa dels nous noms i el canvi de Voice a Staff,\n"
"els ajustaments de disposició per a l'esquema antic no són efectius\n"
"amb el nou esquema.\n"
"\n"
"Si no us agrada la nova disposició predeterminada, heu de treballar\n"
"amb Divisio i Divisio_engraver al context Staff-aliased apropiat.\n"

#: convertrules.py:4679
msgid ""
"\n"
"GregorianTranscriptionStaff now engraves \\divisioMinima,\n"
"\\divisioMaior, and \\divisioMaxima as BarLine grobs using Bar_engraver,\n"
"and engraves \\caesura and \\virgula as Divisio grobs using\n"
"Divisio_engraver.\n"
"\n"
"Previously, GregorianTranscriptionVoice used Breathing_sign_engraver\n"
"to engrave these as BreathingSign grobs.  Because of the new names and\n"
"the move from Voice to Staff, layout adjustments for the old scheme\n"
"are not effective for the new.\n"
"\n"
"If you are not content with the new default layout, deal with BarLine,\n"
"Bar_engraver, Divisio, and Divisio_engraver in\n"
"GregorianTranscriptionStaff context.  \\EnableGregorianDivisiones may\n"
"also be used to switch to engraving Divisio grobs instead of BarLine\n"
"grobs.\n"
msgstr ""
"\n"
"GregorianTranscriptionStaff ara grava \\divisioMinima,\n"
"\\divisioMaior, i \\divisioMaxima com a grobs  BarLine grobs usant\n"
" Bar_engraver, i grava \\caesura i \\virgula com a grobs Divisio \n"
"usant Divisio_engraver.\n"
"\n"
"Anteriorment, GregorianTranscriptionVoice usave Breathing_sign_engraver\n"
"per gravar aquests grobs BreathingSign.  A cause dels nous noms i del\n"
"canvi de Voice a Staff, els ajustaments de disposició per a l'esquema\n"
"antic no són efectius amb el nou.\n"
"\n"
"Si no us agrada la nova disposició predeterminada, heu de treballar \n"
"amb BarLine, Bar_engraver, Divisio, i Divisio_engraver al context\n"
"GregorianTranscriptionStaff.  \\EnableGregorianDivisiones també\n"
"es pot usar per passar a gravar grobs Divisio en comptes de grobs\n"
"BarLine.\n"

#: convertrules.py:4707
msgid "music following \\fine"
msgstr "música després de \\fine"

#: convertrules.py:4712
msgid "BreathingSign to BarLine or Divisio"
msgstr "BreathingSign a BarLine o Divisio"

#: convertrules.py:4717
msgid "BreathingSign to Divisio"
msgstr "BreathingSign a Divisio"

#: convertrules.py:4723
msgid ""
"\n"
"The barAlways property has been removed.  Instead, use\n"
"forbidBreakBetweenBarLines.\n"
msgstr ""
"\n"
"La propietat barAlways s'ha eliminat. En canvi, useu\n"
"forbidBreakBetweenBarLines.\n"

#: convertrules.py:4735
msgid "advanced use of barAlways"
msgstr "ús avançat de barAlways"

#: convertrules.py:4741
msgid ""
"\n"
"The second argument to ly:skylines-for-stencil is now the 'horizon axis',\n"
"which is the opposite of the convention used previously.\n"
msgstr ""
"\n"
"El segon argument per a ly:skylines-for-stencil és ara l'«horizon axis»,\n"
"que és el contrari de la convenció utilitzada anteriorment.\n"

#: convertrules.py:4751
msgid "ly:skylines-for-stencil second argument"
msgstr "ly:skylines-for-stencil segon argument"

#: convertrules.py:4773
msgid ""
"\n"
"The string-regexp-substitute function has been removed.  A call\n"
"\n"
"  (string-regexp-substitute pattern replacement str)\n"
"\n"
"should be replaced with\n"
"\n"
"  (ly:regex-replace (ly:make-regex pattern) str replacement)\n"
msgstr ""
"\n"
"S'ha eliminat la funció string-regexp-substitute.  Una crida\n"
"\n"
"  (string-regexp-substitute pattern replacement str)\n"
"\n"
"s'ha de substituir per\n"
"\n"
"  (ly:regex-replace (ly:make-regex pattern) str replacement)\n"

#: convertrules.py:4783
msgid ""
"\n"
"uniqued-alist no longer needs to take '() as its second argument.\n"
msgstr ""
"\n"
"uniqued-alist ja no necessita prendre '() com el seu segon argument.\n"

#. This replacement is not 100% reliable, but should do a good job.
#. If there is the #:factor (/ staff-height pt 20) parameter in the
#. set-global-fonts call, the user had done what it took to heed any
#. custom font size, so we're fine. If no #:factor was passed, we
#. assume that the user was not changing the font size, as doing that
#. without passing #:factor was resulting in bad output anyway.
#. Other values result in a warning.
#: convertrules.py:4871
#, python-brace-format
msgid ""
"\n"
"LilyPond now uses a different syntax for selecting fonts.  The\n"
"set-global-fonts Scheme function has been removed.  convert-ly\n"
"has mostly converted the call for you, but it was not able to\n"
"convert the #:factor parameter.  Now, font selection is independent\n"
"from setting the font size.  Please use set-global-staff-size\n"
"or layout-set-staff-size to replace this parameter, which you\n"
"set to:\n"
"\n"
"    {}\n"
"\n"
msgstr ""
"\n"
"El LilyPond ara utilitza una sintaxi diferent per a seleccionar tipus de lletra.  La\n"
"funció de l'Scheme set-global-fonts Scheme s'ha eliminat.  convert-ly\n"
"us ha convertit majoritàriament la crida, però no va ser capaç de\n"
"convertir el paràmetre #:factor.  Ara, la selecció de tipus de lletra és independent\n"
"d'establir la mida del tipus de lletra.  Utilitzeu set-global-staff-size\n"
"o layout-set-staff-size per reemplaçar aquest paràmetre, que\n"
"establiu a:\n"
"\n"
"    {}\n"

#: convertrules.py:4884
msgid ""
"\n"
"LilyPond now uses a different syntax for selecting fonts.  The #:brace\n"
"argument to set-global-fonts does not have an equivalent in the new syntax;\n"
"braces now use the normal music font family by default.  Your code contains\n"
"a call to set-global-fonts where the #:music and #:brace parameters have\n"
"different values.  If you wish to set braces in a different music font than\n"
"other music glyphs, use code such as\n"
"\n"
"\\paper {\n"
"  fonts.music-alt = \"your-music-font\"\n"
"}\n"
"\n"
"\\layout {\n"
"  \\context {\n"
"    \\Score\n"
"    \\override SystemStartBrace.font-family = #'music-alt\n"
"  }\n"
"}\n"
msgstr ""
"\n"
"El LilyPond ara utilitza una sintaxi diferent per a seleccionar tipus de lletra.  La  The:brace\n"
"l'argument «set-global-fonts» no té un equivalent en la sintaxi nova;\n"
"Les claus ara utilitzen la família normal de tipus de lletra de música per defecte.  El vostre codi conté\n"
"una crida a set-global-fonts on els paràmetres  the:music i  and:brace tenen\n"
"valors diferents.  Si voleu establir claus en un tipus de lletra de música diferent que\n"
"altres glifs de música, utilitzeu codi com\n"
"\n"
"\\paper {\n"
"  fonts.music-alt \" «your-music-font»\n"
"}\n"
"\n"
"\\layout {\n"
"  \\context {\n"
"    \\Score\n"
"    \\override SystemStartBrace.font-family    'music-alt\n"
"  }\n"
"}\n"

#: convertrules.py:4904
msgid ""
"\n"
"LilyPond now uses a different syntax for selecting fonts. The code equivalent\n"
"to the previous spelling\n"
"\n"
"\\paper {\n"
"  #(define fonts\n"
"     (set-global-fonts #:music \"music-font\"\n"
"                       #:brace \"brace-font\"\n"
"                       #:roman \"roman font\"\n"
"                       #:sans \"sans font\"\n"
"                       #:typewriter \"typewriter font\"))\n"
"}\n"
"\n"
"is now\n"
"\n"
"\\paper {\n"
"  fonts.music = \"music-font\"\n"
"  fonts.roman = \"roman font\"\n"
"  fonts.sans = \"sans font\"\n"
"  fonts.typewriter = \"typewriter font\"\n"
"}\n"
"\n"
"convert-ly found an advanced use of set-global-fonts that it was not able to\n"
"convert automatically.  Please do the update manually.\n"
msgstr ""
"\n"
"El LilyPond usa ara una sintaxi diferent per a la selecció de tipus de\n"
"lletra. L'equivalent de codi per a la sintaxi prèvia\n"
"\n"
"\\paper {\n"
"  #(define fonts\n"
"     (set-global-fonts #:music \"music-font\"\n"
"                       #:brace \"brace-font\"\n"
"                       #:roman \"roman font\"\n"
"                       #:sans \"sans font\"\n"
"                       #:typewriter \"typewriter font\"))\n"
"}\n"
"\n"
"és ara\n"
"\n"
"\\paper {\n"
"  fonts.music = \"music-font\"\n"
"  fonts.roman = \"roman font\"\n"
"  fonts.sans = \"sans font\"\n"
"  fonts.typewriter = \"typewriter font\"\n"
"}\n"
"\n"
"convert-ly ha trobat un ús avançat de set-global-fonts que no ha pogut\n"
"convertir automàticament. Si us plau actualitzeu manualment.\n"

#: convertrules.py:4949
msgid "#:factor parameter to set-global-fonts"
msgstr "paràmetre #:factor per a set-global-fonts"

#: convertrules.py:4954
msgid "different music and brace fonts passed to set-global-fonts"
msgstr "diferents tipus de lletra de música i claus van passar a set-global-fonts"

#: convertrules.py:4971
msgid "advanced use of set-global-fonts"
msgstr "ús avançat de set-global-fonts"

#. Similar logic here with the factor parameter here
#: convertrules.py:4976
#, python-brace-format
msgid ""
"\n"
"LilyPond now uses a different syntax for selecting fonts.  The\n"
"make-pango-font-tree Scheme function has been removed.  convert-ly\n"
"has mostly converted the call for you, but it was not able to\n"
"convert the #:factor parameter.  Now, font selection is independent\n"
"from setting the font size.  Please use set-global-staff-size\n"
"or layout-set-staff-size to replace this parameter, which you\n"
"set to:\n"
"\n"
"    {}\n"
"\n"
msgstr ""
"\n"
"El LilyPond ara utilitza una sintaxi diferent per a seleccionar el\n"
"tipus de lletra.  S'ha eliminat la funció make-pango-font-tree de\n"
"l'Scheme».  convert-ly us ha convertit majoritàriament la crida, però\n"
"no va ser capaç de convertir el paràmetre #:factor.  Ara, la selecció\n"
"de tipus de lletra és independent d'establir la mida del tipus de\n"
"lletra.  Utilitzeu set-global-staff-size o layout-set-staff-size per\n"
"reemplaçar aquest paràmetre, que establiu a\n"
"\n"
"    {}\n"

#: convertrules.py:4989
msgid ""
"\n"
"LilyPond now uses a different syntax for selecting fonts. The code equivalent\n"
"to the previous spelling\n"
"\n"
"\\paper {\n"
"  #(define fonts\n"
"     (make-pango-font-tree\n"
"       \"roman font\"\n"
"       \"sans font\"\n"
"       \"typewriter font\"\n"
"       factor))\n"
"}\n"
"\n"
"is now\n"
"\n"
"\\paper {\n"
"  fonts.roman = \"roman font\"\n"
"  fonts.sans = \"sans font\"\n"
"  fonts.typewriter = \"typewriter font\"\n"
"}\n"
"\n"
"convert-ly found an advanced use of make-pango-font-tree that it was not able\n"
"to convert automatically.  Please do the update manually.\n"
msgstr ""
"\n"
"El LilyPonde usa ara una sintaxi diferent per seleccionar el tipus de\n"
"lletra. El codi equivalent a la sintaxi anterior \n"
"\n"
"\\paper {\n"
"  #(define fonts\n"
"     (make-pango-font-tree\n"
"       \"roman font\"\n"
"       \"sans font\"\n"
"       \"typewriter font\"\n"
"       factor))\n"
"}\n"
"\n"
"és ara\n"
"\n"
"\\paper {\n"
"  fonts.roman = \"roman font\"\n"
"  fonts.sans = \"sans font\"\n"
"  fonts.typewriter = \"typewriter font\"\n"
"}\n"
"\n"
"convert-ly ha trobat un ús avançat de make-pango-font-tree que no ha\n"
"pogut convertir automàticament.  Si us plau actualitzeu manualment.\n"

#: convertrules.py:5036
msgid "factor parameter to make-pango-font-tree"
msgstr "paràmetre factor a make-pango-font-tree"

#: convertrules.py:5047
msgid "advanced use of make-pango-font-tree"
msgstr "ús avançat de make-pango-font-tree"

#: convertrules.py:5103
msgid "markup in repeatCommands"
msgstr "marcatge a repeatCommands"

#: convertrules.py:5104
msgid ""
"\n"
"Markups inside repeatCommands are no longer automatically typeset in\n"
"a music font. Use the \\volta-number command where needed. Example\n"
"replacements:\n"
"\n"
"  \\set Score.repeatCommands = #'((volta \"ad lib.\"))\n"
"  [does not need conversion]\n"
"\n"
"  \\set Score.repeatCommands = #'((volta \"1.2.\"))\n"
"  -> \\set Score.repeatCommands = #`((volta ,#{ \\markup \\volta-number \"1.2.\" #}))\n"
"\n"
"  \\set Score.repeatCommands = #'((volta \"1.2. ad lib.\"))\n"
"  -> \\set Score.repeatCommands = #`((volta ,#{ \\markup { \\volta-number \"1.2.\" ad lib. } #}))\n"
msgstr ""
"\n"
"Els marcatges dins de repeatCommands no s'escriuen automàticament en\n"
"un tipus de lletra de música. Useu l'ordre \\volta-number quan calgui.\n"
"Exemples de substitucions:\n"
"\n"
"  \\set Score.repeatCommands = #'((volta \"ad lib.\"))\n"
"  [does not need conversion]\n"
"\n"
"  \\set Score.repeatCommands = #'((volta \"1.2.\"))\n"
"  -> \\set Score.repeatCommands = #`((volta ,#{ \\markup \\volta-number \"1.2.\" #}))\n"
"\n"
"  \\set Score.repeatCommands = #'((volta \"1.2. ad lib.\"))\n"
"  -> \\set Score.repeatCommands = #`((volta ,#{ \\markup { \\volta-number \"1.2.\" ad lib. } #}))\n"

#: convertrules.py:5138
msgid "advanced use of (text-)font-defaults"
msgstr "ús avançat de (text-)font-defaults"

#: convertrules.py:5139
msgid ""
"\n"
"The text-font-defaults and font-defaults variables have\n"
"been merged into a single property-defaults variable.\n"
msgstr ""
"\n"
"Les variables text-font-defaults i font-defaults tenen\n"
"s'ha fusionat en una única variable de propietat per defecte.\n"

#: convertrules.py:5145
#, python-brace-format
msgid ""
"\n"
"Identifiers formerly in file 'gregorian.ly' are now always defined.  The\n"
"following variable or variables in your LilyPond input file have the same\n"
"name as one of these identifiers:\n"
"\n"
"  {}\n"
"\n"
"It is recommended to rename them.\n"
msgstr ""
"\n"
"Els identificadors que hi havia al fitxer «gregorian.ly» ara sempre estan definits.  El\n"
"la variable o variables següents al fitxer d'entrada del LilyPond tenen el mateix\n"
"nom com un d'aquests identificadors:\n"
"\n"
"  {}\n"
"\n"
"Es recomana canviar-ne el nom.\n"

#: convertrules.py:5155
msgid ""
"\n"
"The use of 'gregorian.ly' is deprecated.  Code like\n"
"\n"
"  \\input \"gregorian.ly\"\n"
"\n"
"  \\new VaticanaStaff { ... }\n"
"\n"
"should be replaced with\n"
"\n"
"  \\new VaticanaScore {\n"
"    \\new VaticanaStaff { ... }\n"
"  }\n"
"\n"
"  \\layout {\n"
"    indent = 0\n"
"    ragged-last = ##t\n"
"  }\n"
"\n"
msgstr ""
"\n"
"L'ús de 'gregorian.ly' és obsolet.  Com un codi\n"
"\n"
"  \\input \"gregorian.ly\"\n"
"\n"
"  \\new VaticanaStaff { ... }\n"
"\n"
"s'ha de substituir per\n"
"\n"
"  \\new VaticanaScore {\n"
"    \\new VaticanaStaff { ... }\n"
"  }\n"
"\n"
"  \\layout {\n"
"    sagnat   0\n"
"    ragged-last    t\n"
"  }\n"

#: convertrules.py:5216
msgid "gregorian.ly to VaticanaScore"
msgstr "gregorian.ly a VaticanaScore"

#: convertrules.py:5232
msgid "possible use of \\roman markup command with #(markup ...) macro"
msgstr "possible ús de l'ordre de marcatge \\roman amb la macro #(markup ...)"

#: convertrules.py:5234
msgid ""
"\n"
"convert-ly detected \"#:roman\" in the input file.  This may be\n"
"related to using the \\roman markup command with the markup\n"
"macro, e.g., #(markup #:roman ...).  If this is the case, convert\n"
"#:roman to #:serif.\n"
msgstr ""
"\n"
"convert-ly ha detectat \"#:roman\" al fitxer d'entrada. Això pot estar\n"
"relacionat amb l'ús de l'ordre de marcatge \\roman amb el macro de\n"
"marcatge, p. e. #(markup #:roman ...).  Si és aquest el cas, convertiu\n"
"#:roman a #:serif.\n"

#: convertrules.py:5278
msgid "subdivideBeams"
msgstr "subdivideBeams"

#: convertrules.py:5279
msgid ""
"\n"
"Context property 'subdivideBeams' used to rely on the value of\n"
"'baseMoment' for the minimum subdivision interval.  Now, separate\n"
"properties 'minimumBeamSubdivisionInterval',\n"
"'maximumBeamSubdivisionInterval', and 'respectIncompleteBeams'\n"
"specifically control beam subdivision intervals, whereas 'baseMoment' no\n"
"longer has an effect.  The value of 'baseMoment' may implicitly change\n"
"whenever a time signature changes or is first set, so preserving past\n"
"behavior requires setting 'minimumBeamSubdivisionInterval' to the same\n"
"value of 'baseMoment', even at each implicit setting of 'baseMoment',\n"
"and setting 'respectIncompleteBeams' to true.\n"
msgstr ""
"\n"
"Propietat contextual «subdivideBeams» utilitzada per confiar en el\n"
"valor de «baseMoment» per a l'interval mínim de subdivisió.  Ara,\n"
"propietats separades «minimumBeamSubdivisionInterval»,\n"
"'maximumBeamSubdivisionInterval', i «respectIncompleteBeams» controlen\n"
"específicament els intervals de subdivisió del barrat, mentre que\n"
"«baseMoment« no té més aquest efecte.  El valor de «baseMoment» pot\n"
"canviar implícitament cada vegada que una signatura de temps canvia o\n"
"s'estableix per primera vegada, de manera que preservar el\n"
"comportament passat requereix establir\n"
"«minimumBeamSubdivisionInterval» al mateix valor de «baseMoment», fins\n"
"i tot en cada paràmetre implícit de «baseMoment», i establir\n"
"«respectIncompleteBeams» a cert.\n"

#: convertrules.py:5475
msgid "Advanced use of partcombine music types."
msgstr "Ús avançat de tipus de música partcombine."

#: convertrules.py:5476
msgid ""
"\n"
"UnisonoEvent, SoloOneEvent, and SoloTwoEvent have been merged into\n"
"PartCombineEvent, with different values for property 'part-combine-status:\n"
"'unisono, 'solo1, 'solo2 respectively.\n"
msgstr ""
"\n"
"UnisonoEvent, SoloOneEvent i SoloTwoEvent s'han fusionat a\n"
"PartCombineEvent, amb diferents valors per a la propietat 'part-combine-status:\n"
"'unisono, 'solo1, 'solo2 respectivament.\n"

#: convertrules.py:5483
msgid "Advanced use of partcombine event classes."
msgstr "Ús avançat de les classes d'esdeveniments de partcombine."

#: convertrules.py:5484
msgid ""
"\n"
"unisono-event, solo-one-event, and solo-two-event have been removed. Instead,\n"
"use part-combine-event with different values for property 'part-combine-status:\n"
"'unisono, 'solo1, 'solo2 respectively.\n"
msgstr ""
"\n"
"Unisono-event, solo-one-event i solo-two-event han estat eliminats. En lloc d'això, useu  part-combine-event amb diferents valors per a la\n"
"propietat 'part-combine-status:\n"
"'unisono, 'solo1, 'solo2 respectivament.\n"

#: convertrules.py:5491
msgid ""
"\n"
"Advanced use of make-part-combine-marks or make-part-combine-context-changes.\n"
msgstr ""
"\n"
"Ús avançat de make-part-combine-marks o make-part-combine-context-changes.\n"

#: convertrules.py:5494
msgid ""
"\n"
"The format of values returned by all partcombine state machine tables was\n"
"changed:\n"
"\n"
"  1. 'next-label' symbols moved from LAST to FIRST\n"
"  2. Values are now always proper lists (changed from dotted pairs for\n"
"     context-changes table)\n"
"\n"
"The order of arguments to make-part-combine-marks was reversed (but not for\n"
"make-part-combine-context-changes). The state-machine argument is now optional,\n"
"and expects a procedure rather than a state-machine table. For equivalent\n"
"behavior, pass:\n"
"        (traverse-state-machine <your-state-machine-table>)\n"
"as the second argument.\n"
"\n"
"Refer to part-combiner.scm for more information.\n"
msgstr ""
"\n"
"El format dels valors retornats per totes les taules de màquines d'estats partcombine ha canviat:\n"
"\n"
"  1. Els símbols «next-label» s'han mogut de LAST a FIRST\n"
"  2. Els valors són ara sempre llistes pròpiament (canviades de parelless amb punt per a taula de context-changes)\n"
"\n"
"L'ordre dels arguments per a «make-part-combine-marks» s'ha invertit\n"
"(però no per a make-part-combine-context-changes). L'argument\n"
"de state-machine ara és opcional, i espera un procediment en lloc d'una taula de state-machine. Per a un comportament equivalent\n"
"passeu:\n"
"        (traversa-estat-màquina <your-state-machine-table>)\n"
"com a segon argument.\n"
"\n"
"Consulteu part-combiner.scm per a més informació.\n"

#: convertrules.py:5572
msgid "toe and heel marks with direction modifiers"
msgstr "marques de dit i taló amb modificadors de direcció"

#: convertrules.py:5573
msgid ""
"\n"
"\\rtoe, \\ltoe, \\rheel, and \\lheel now ignore them.  Three possible solutions:\n"
"  - use the `toeHeelStyle` context property to style the pedal mark commands\n"
"    instead of specifying explicit directions (preferred)\n"
"  - use normal articulations \\toe, \\vartoe, \\heel, or \\varheel\n"
"  - remove `Toe_heel_engraver`\n"
msgstr ""
"\n"
"\\rtoe, \\ltoe, \\rheel i \\lheel ara els ignoren.  Tres possibles solucions:\n"
"  - utilitzeu la propietat contextual `toeHeelStyles` per a estilitzar\n"
"    les ordres de marca de pedal en lloc d'especificar direccions\n"
"    explícites (preferit)\n"
"  - utilitzeu articulacions normals \\toe, \\vartoe, \\heel, o \\varheel\n"
"  - elimineu  `Toe_heel_engraver`\n"

#: convertrules.py:5635
msgid "assignment of \\%"
msgstr "assignació de \\%"

#: convertrules.py:5636
msgid ""
"\n"
"\\% is now a built-in abbreviation for \\repeat percent.  If you have defined it\n"
"differently, you may wish to change the name to avoid confusion.\n"
msgstr ""
"\n"
"\\% és ara una abreviatura integrada per \\repeat percent.  Si l'heu definit\n"
"D'una altra manera, és possible que vulgueu canviar el nom per evitar confusions.\n"

#: convertrules.py:5643
msgid "assignment of \\*"
msgstr "assignació de \\*"

#: convertrules.py:5644
msgid ""
"\n"
"\\* is now a built-in abbreviation for \\repeat unfold.  If you have defined it\n"
"differently, you may wish to change the name to avoid confusion.\n"
msgstr ""
"\n"
"\\* és ara una abreviatura incorporada per al desplegament de \\repeat.\n"
"Si l'heu definit D'una altra manera, és possible que vulgueu canviar\n"
"el nom per evitar confusions.\n"

#: convertrules.py:5667
msgid "chord names in combination with \\language"
msgstr "noms d'acords en combinació amb \\language"

#: convertrules.py:5668
msgid ""
"\n"
"\\germanChords and its siblings no longer depend on the input note names\n"
"as selected with \\language.  This might cause different note names in the\n"
"shown chord names.\n"
msgstr ""
"\n"
"\\germanChords i els seus germans ja no depenen dels noms de les notes\n"
"d'entrada seleccionats amb \\language.  Això pot causar diferents\n"
"noms de notes en els noms dels acords que es mostren.\n"

